{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedCorsOrigins": [
    "http://localhost:37387",
    "https://newwords.shukebeta.com"
  ],
  "DatabaseConnectionOptions": {
    "ConnectionString": "Server=127.0.0.1; database=NewWords; uid=default_user; port=6307; password=PRODUCTION_MYSQL_PASSWORD; charset=utf8mb4;",
    "DbType":"MySql",
    "ApplicationName": "NewWords"
  },
  "Jwt": {
    "Issuer": "https://new-words-api.shukebeta.com",
    "SymmetricSecurityKey": "PRODUCTION_SYMMETRIC_SECURITY_KEY"
  },
  "Redis": {
    "ConnectionString": "PRODUCTION_REDIS_CONNECTION",
    "Database": 0,
    "ProjectPrefix": "newwords.api"
  },
  // "ApiKey":"XAI_API_KEY" is a deploy-time placeholder, not a literal key: the Publish
  // step in .github/workflows/deploy_to_production.yml sed-substitutes the "XAI_API_KEY"
  // token with the GitHub secret at publish. In production, Redis (ConfigManager.Provider,
  // issue #19) is registered last and overrides Agents:* anyway. Startup fails fast if this
  // placeholder is still present in Production (issue #6). Locally, set the real key in the
  // git-ignored appsettings.Local.json.
  "Agents":[
    {
      "Provider":"openrouter",
      "BaseUrl":"https://openrouter.ai/api/v1",
      "ApiKey":"XAI_API_KEY",
      "Models": [
        "google/gemma-4-26b-a4b-it",
        "anthropic/claude-3.5-haiku"
      ]
    }
  ],
  // PreferredModels pins the explanation fallback order independently of Agents[*].Models;
  // it happens to match today. LanguageService.SelectExplanationAgents orders by this list,
  // then appends any remaining agents in declaration order.
  "Explanation": {
    "PreferredModels": [
      "google/gemma-4-26b-a4b-it",
      "anthropic/claude-3.5-haiku"
    ]
  },
  // Free (non-premium) saved-word cap (issue #37). Read on every add via EntitlementService,
  // so a Redis/ConfigManager override ("newwords.api:Subscription:FreeWordCap") takes effect
  // without redeploy. Falls back to 500 when unset or non-positive.
  "Subscription": {
    "FreeWordCap": 500
  },
  "SupportedLanguages": [
    { "code": "en", "name": "English" },
    { "code": "zh-CN", "name": "Chinese (Simplified)" },
    { "code": "zh-TW", "name": "Chinese (Traditional)" },
    { "code": "hi", "name": "Hindi" },
    { "code": "es", "name": "Spanish" },
    { "code": "fr", "name": "French" },
    { "code": "ar", "name": "Arabic (Modern Standard)" },
    { "code": "bn", "name": "Bengali" },
    { "code": "ru", "name": "Russian" },
    { "code": "pt", "name": "Portuguese" },
    { "code": "ur", "name": "Urdu" },
    { "code": "id", "name": "Indonesian" },
    { "code": "de", "name": "German" },
    { "code": "ja", "name": "Japanese" },
    { "code": "ko", "name": "Korean" },
    { "code": "tr", "name": "Turkish" },
    { "code": "ta", "name": "Tamil" },
    { "code": "vi", "name": "Vietnamese" },
    { "code": "tl", "name": "Tagalog" },
    { "code": "fa", "name": "Farsi (Persian)" },
    { "code": "it", "name": "Italian" },
    { "code": "th", "name": "Thai" },
    { "code": "pl", "name": "Polish" },
    { "code": "nl", "name": "Dutch" },
    { "code": "sv", "name": "Swedish" }
  ],
  "VERSION":"VERSION_PLACEHOLDER",
  "AllowedHosts":"*"
}
